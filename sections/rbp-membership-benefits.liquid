<section class="rbp-section">
  <div class="rbp-container">
    {% render 'rbp-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text %}
    <div class="rbp-card-grid">
      {%- for block in section.blocks -%}
        <article class="rbp-card" {{ block.shopify_attributes }}>
          <span class="rbp-badge">{{ block.settings.badge | escape }}</span>
          <h3 class="rbp-card__title">{{ block.settings.title | escape }}</h3>
          <p class="rbp-card__text">{{ block.settings.text | escape }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RBP membership benefits",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Membership" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Member benefits" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use blocks to explain membership inclusions and partner support.</p>" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge", "default": "Included" },
        { "type": "text", "id": "title", "label": "Title", "default": "Member support" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "A reusable benefit card for membership pages." }
      ]
    }
  ],
  "presets": [
    {
      "name": "RBP membership benefits",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit", "settings": { "title": "Partner pricing", "text": "Explain partner or member commercial benefits." } },
        { "type": "benefit", "settings": { "title": "Resource access", "text": "Link benefits back to resource and service pathways." } }
      ]
    }
  ]
}
{% endschema %}
