<section class="rbp-hero rbp-section">
  <div class="rbp-container rbp-hero__grid">
    <div class="rbp-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="rbp-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1 class="rbp-heading rbp-heading--xl">{{ section.settings.heading | escape }}</h1>
      {%- if section.settings.text != blank -%}
        <div class="rbp-copy">{{ section.settings.text }}</div>
      {%- endif -%}
      <div class="rbp-actions">
        {%- if section.settings.primary_label != blank -%}
          {% render 'rbp-button', label: section.settings.primary_label, url: section.settings.primary_url, variant: 'primary', size: 'large', arrow: true %}
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          {% render 'rbp-button', label: section.settings.secondary_label, url: section.settings.secondary_url, variant: 'secondary', size: 'large' %}
        {%- endif -%}
      </div>
    </div>
    <div class="rbp-hero__panel" aria-label="{{ section.settings.panel_label | escape }}">
      <div class="rbp-hero__panel-card">
        <span class="rbp-badge">{{ section.settings.panel_badge | escape }}</span>
        <h2 class="rbp-card__title">{{ section.settings.panel_heading | escape }}</h2>
        <p class="rbp-card__text">{{ section.settings.panel_text | escape }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RBP hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Remote Business Partner" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Practical business support for Australian operators" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Choose the right pathway for decisions, planning, implementation, operations, resources or support.</p>" },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Find the right support pathway" },
    { "type": "url", "id": "primary_url", "label": "Primary button URL" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Browse resources" },
    { "type": "url", "id": "secondary_url", "label": "Secondary button URL" },
    { "type": "text", "id": "panel_label", "label": "Panel accessibility label", "default": "RBP service pathway summary" },
    { "type": "text", "id": "panel_badge", "label": "Panel badge", "default": "Start here" },
    { "type": "text", "id": "panel_heading", "label": "Panel heading", "default": "Choose the right pathway" },
    { "type": "textarea", "id": "panel_text", "label": "Panel text", "default": "Start with advisory, consulting, implementation, operations, resources or support depending on what the business needs next." }
  ],
  "presets": [
    { "name": "RBP hero" }
  ]
}
{% endschema %}
