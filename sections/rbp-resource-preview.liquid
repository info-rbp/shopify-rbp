<section class="rbp-section rbp-surface">
  <div class="rbp-container">
    {% render 'rbp-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text %}
    <div class="rbp-resource-grid">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          {% render 'rbp-resource-card',
            title: block.settings.title,
            text: block.settings.text,
            type: block.settings.type,
            url: block.settings.url
          %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RBP resource preview",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Resources" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Useful resources before the next step" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Preview guides, templates, checklists or documents from the resource hub.</p>" }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Resource",
      "settings": [
        { "type": "text", "id": "type", "label": "Type", "default": "Guide" },
        { "type": "text", "id": "title", "label": "Title", "default": "Business readiness checklist" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "A practical checklist for preparing the next decision." },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "RBP resource preview",
      "blocks": [
        { "type": "resource" },
        { "type": "resource", "settings": { "type": "Template", "title": "Requirements brief", "text": "Capture what the work needs before handover." } },
        { "type": "resource", "settings": { "type": "Checklist", "title": "Post-purchase next steps", "text": "Set up the intake, booking or review process." } }
      ]
    }
  ]
}
{% endschema %}
