<section class="rbp-section rbp-surface">
  <div class="rbp-container">
    {% render 'rbp-section-heading',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      text: section.settings.text,
      align: section.settings.align,
      size: 'lg'
    %}
  </div>
</section>

{% schema %}
{
  "name": "RBP page hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "RBP" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page title" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use this section for concise page introductions before modular content blocks.</p>" },
    {
      "type": "select",
      "id": "align",
      "label": "Alignment",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ]
    }
  ],
  "presets": [
    { "name": "RBP page hero" }
  ]
}
{% endschema %}
