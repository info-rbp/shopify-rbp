<section class="rbp-section rbp-surface">
  <div class="rbp-container">
    {% render 'rbp-section-heading',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      text: section.settings.text,
      align: section.settings.align
    %}
  </div>
</section>

{% schema %}
{
  "name": "RBP collection intro",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collection guide" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Browse with the right context" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use this intro to explain the collection before Shopify filtering, sorting and pagination.</p>" },
    {
      "type": "select",
      "id": "align",
      "label": "Alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    }
  ],
  "presets": [
    { "name": "RBP collection intro" }
  ]
}
{% endschema %}
