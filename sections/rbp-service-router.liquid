<section class="rbp-section">
  <div class="rbp-container">
    {% render 'rbp-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text %}
    <div class="rbp-router">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          {% render 'rbp-service-card',
            title: block.settings.title,
            text: block.settings.text,
            url: block.settings.url,
            button_label: block.settings.button_label,
            icon: block.settings.icon
          %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RBP service router",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Choose a pathway" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Start with the kind of support you need" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Choose the route that matches the business need: decision support, planning, implementation, operations, resources or support.</p>" }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service card",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon text", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Advisory" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Clarify decisions, risks and next steps before committing budget or time." },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "View pathway" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "RBP service router",
      "blocks": [
        { "type": "service" },
        { "type": "service", "settings": { "icon": "02", "title": "Implementation", "text": "Turn approved work into practical setup, documentation and handover." } },
        { "type": "service", "settings": { "icon": "03", "title": "Operations Hub", "text": "Find services, resources and support for recurring operational work." } }
      ]
    }
  ]
}
{% endschema %}
