<section
  class="
    rbp-trust-strip
    rbp-trust-strip--{{ section.settings.layout }}
    {% if section.settings.show_top_border %}rbp-trust-strip--top-border{% endif %}
    {% if section.settings.show_bottom_border %}rbp-trust-strip--bottom-border{% endif %}
  "
  style="
    --rbp-trust-strip-bg: {{ section.settings.background_color }};
    --rbp-trust-strip-text: {{ section.settings.text_color }};
    --rbp-trust-strip-padding-top: {{ section.settings.section_padding_top }}px;
    --rbp-trust-strip-padding-bottom: {{ section.settings.section_padding_bottom }}px;
  "
>
  <div class="rbp-trust-strip__inner rbp-container--wide">
    {%- if section.settings.heading != blank or section.settings.body != blank -%}
      <div class="rbp-trust-strip__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="rbp-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="rbp-heading rbp-heading--md">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="rbp-trust-strip__body rte">{{ section.settings.body }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="rbp-trust-strip__items" role="list" aria-label="{{ section.settings.heading | default: 'Trust and support points' | escape }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign item_title = block.settings.heading | default: 'Trust point'
          assign icon_text = 'OK'
          case block.settings.icon
            when 'scope'
              assign icon_text = 'SC'
            when 'delivery'
              assign icon_text = 'DD'
            when 'support'
              assign icon_text = 'SP'
            when 'secure'
              assign icon_text = 'SE'
            when 'resource'
              assign icon_text = 'RS'
            when 'check'
              assign icon_text = 'OK'
          endcase
        -%}

        {%- if block.settings.link != blank -%}
          <a
            class="rbp-trust-strip__item"
            href="{{ block.settings.link }}"
            role="listitem"
            {{ block.shopify_attributes }}
          >
            <span class="rbp-trust-strip__icon" aria-hidden="true">{{ icon_text }}</span>
            <span class="rbp-trust-strip__content">
              <span class="rbp-trust-strip__title">{{ item_title | escape }}</span>
              {%- if block.settings.body != blank -%}
                <span class="rbp-trust-strip__text">{{ block.settings.body | escape }}</span>
              {%- endif -%}
            </span>
          </a>
        {%- else -%}
          <article class="rbp-trust-strip__item" role="listitem" {{ block.shopify_attributes }}>
            <span class="rbp-trust-strip__icon" aria-hidden="true">{{ icon_text }}</span>
            <span class="rbp-trust-strip__content">
              <span class="rbp-trust-strip__title">{{ item_title | escape }}</span>
              {%- if block.settings.body != blank -%}
                <span class="rbp-trust-strip__text">{{ block.settings.body | escape }}</span>
              {%- endif -%}
            </span>
          </article>
        {%- endif -%}
      {%- else -%}
        {%- if request.design_mode -%}
          <div class="rbp-trust-strip__empty">
            Trust and support details will appear here when configured.
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .rbp-trust-strip {
    padding-block: var(--rbp-trust-strip-padding-top, 32px) var(--rbp-trust-strip-padding-bottom, 32px);
    background: var(--rbp-trust-strip-bg, #ffffff);
    color: var(--rbp-trust-strip-text, var(--rbp-ink, #0f172a));
  }

  .rbp-trust-strip--top-border {
    border-top: 1px solid var(--rbp-line, rgba(15, 23, 42, 0.1));
  }

  .rbp-trust-strip--bottom-border {
    border-bottom: 1px solid var(--rbp-line, rgba(15, 23, 42, 0.1));
  }

  .rbp-trust-strip__inner {
    display: grid;
    gap: clamp(2rem, 3vw, 3.2rem);
  }

  .rbp-trust-strip--inline .rbp-trust-strip__inner {
    grid-template-columns: minmax(24rem, 0.44fr) minmax(0, 1fr);
    align-items: center;
  }

  .rbp-trust-strip__header {
    max-width: 58rem;
  }

  .rbp-trust-strip__header > * + * {
    margin-top: 1.2rem;
  }

  .rbp-trust-strip__body {
    color: var(--rbp-slate, #475569);
    line-height: var(--rbp-line-body, 1.65);
  }

  .rbp-trust-strip__body p {
    margin-block: 0;
  }

  .rbp-trust-strip__items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr));
    gap: 1.2rem;
  }

  .rbp-trust-strip__item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1.2rem;
    align-items: start;
    min-height: 8.8rem;
    border: 1px solid var(--rbp-line, rgba(15, 23, 42, 0.1));
    border-radius: var(--rbp-radius-lg, 1.8rem);
    background: rgba(255, 255, 255, 0.78);
    padding: 1.6rem;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 0.8rem 2.4rem rgba(15, 23, 42, 0.04);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  a.rbp-trust-strip__item:hover {
    border-color: rgba(29, 78, 216, 0.24);
    box-shadow: 0 1.4rem 3rem rgba(15, 23, 42, 0.08);
    transform: translateY(-1px);
  }

  .rbp-trust-strip__item:focus-visible {
    outline: 3px solid rgba(37, 99, 235, 0.35);
    outline-offset: 4px;
  }

  .rbp-trust-strip__icon {
    display: inline-grid;
    place-items: center;
    width: 4rem;
    height: 4rem;
    border-radius: 999px;
    background: var(--rbp-blue-soft, #dbeafe);
    color: var(--rbp-blue-dark, #1e3a8a);
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1;
  }

  .rbp-trust-strip__content {
    display: grid;
    gap: 0.45rem;
  }

  .rbp-trust-strip__title {
    color: var(--rbp-ink, #0f172a);
    font-size: 1.55rem;
    font-weight: var(--rbp-weight-strong, 800);
    line-height: 1.25;
  }

  .rbp-trust-strip__text {
    color: var(--rbp-slate, #475569);
    font-size: 1.35rem;
    line-height: 1.45;
  }

  .rbp-trust-strip__empty {
    border: 1px dashed var(--rbp-line-strong, rgba(15, 23, 42, 0.16));
    border-radius: var(--rbp-radius-lg, 1.8rem);
    padding: 2rem;
    color: var(--rbp-slate, #475569);
  }

  @media screen and (max-width: 989px) {
    .rbp-trust-strip--inline .rbp-trust-strip__inner {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 699px) {
    .rbp-trust-strip__items {
      grid-template-columns: 1fr;
    }

    .rbp-trust-strip__item {
      min-height: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rbp-trust-strip__item {
      transition: none;
    }

    a.rbp-trust-strip__item:hover {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RBP trust strip",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Trust and support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clear pathways before you proceed"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Delivery, support and scope expectations stay clear before you choose a pathway or checkout.</p>"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "stacked", "label": "Stacked" },
        { "value": "inline", "label": "Inline heading" }
      ],
      "default": "stacked"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0F172A"
    },
    {
      "type": "checkbox",
      "id": "show_top_border",
      "label": "Show top border",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_bottom_border",
      "label": "Show bottom border",
      "default": false
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon style",
          "options": [
            { "value": "scope", "label": "Scope" },
            { "value": "delivery", "label": "Delivery" },
            { "value": "support", "label": "Support" },
            { "value": "secure", "label": "Secure" },
            { "value": "resource", "label": "Resource" },
            { "value": "check", "label": "Check" }
          ],
          "default": "scope"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Clear scope"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Clear inclusions and boundaries before checkout."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "RBP trust strip",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "scope",
            "heading": "Clear scope",
            "body": "Clear inclusions and boundaries before checkout."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "delivery",
            "heading": "Digital delivery",
            "body": "Digital delivery where applicable."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "support",
            "heading": "Support available",
            "body": "Supported pathways available for selected resources."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "secure",
            "heading": "Secure checkout",
            "body": "Secure Shopify checkout."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "resource",
            "heading": "Practical resources",
            "body": "Built for practical business use."
          }
        }
      ]
    }
  ]
}
{% endschema %}
