          "id": "link_label",
          "label": "Link label",
          "default": "View pathway"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "image_alt_text",
          "label": "Image alt text"
        },
