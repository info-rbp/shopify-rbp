{{ 'rbp-onboarding-form.css' | asset_url | stylesheet_tag }}
<script src="{{ 'rbp-onboarding-form.js' | asset_url }}" defer="defer"></script>

<section class="rbp-onboarding-form-section">
  <div class="rbp-container">
    <div class="rbp-onboarding-intro">
      <p class="rbp-onboarding-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h1 class="rbp-heading rbp-heading--lg">{{ section.settings.heading | escape }}</h1>
      <div class="rbp-onboarding-description">{{ section.settings.text }}</div>
    </div>
    <form class="rbp-onboarding-container" method="post" action="{{ section.settings.action_url }}" data-rbp-onboarding-form>
      <input type="hidden" name="formType" value="{{ section.settings.form_type | escape }}">
      <input type="hidden" name="urlContext" value="">
      <div class="rbp-onboarding-fields">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
            {% render 'rbp-onboarding-field', block: block %}
          </div>
        {%- endfor -%}
      </div>
      <div class="rbp-onboarding-submit">
        <button class="rbp-button rbp-button--primary rbp-button--large" type="submit">{{ section.settings.button_label | escape }}</button>
        <div class="rbp-onboarding-status-message rbp-onboarding-hidden" data-rbp-onboarding-message></div>
      </div>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "RBP onboarding form",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Onboarding" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tell us what needs to happen next" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Share the business context, product or service pathway, timing and next step needed. Avoid passwords, account credentials and unnecessary sensitive information.</p>" },
    { "type": "text", "id": "action_url", "label": "Form action URL", "default": "/apps/rbp-bridge/api/onboarding" },
    { "type": "text", "id": "form_type", "label": "Form type", "default": "general_onboarding" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Submit onboarding details" }
  ],
  "blocks": [
    {
      "type": "field",
      "name": "Field",
      "settings": [
        {
          "type": "select",
          "id": "type",
          "label": "Field type",
          "default": "text",
          "options": [
            { "value": "text", "label": "Text" },
            { "value": "email", "label": "Email" },
            { "value": "tel", "label": "Phone" },
            { "value": "textarea", "label": "Textarea" },
            { "value": "select", "label": "Select" },
            { "value": "checkbox", "label": "Checkbox" },
            { "value": "radio", "label": "Radio" },
            { "value": "hidden", "label": "Hidden" }
          ]
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Business name" },
        { "type": "text", "id": "name", "label": "Input name", "default": "businessName" },
        { "type": "text", "id": "placeholder", "label": "Placeholder" },
        { "type": "textarea", "id": "options", "label": "Options", "info": "One option per line for select or radio fields." },
        { "type": "textarea", "id": "help_text", "label": "Help text" },
        { "type": "checkbox", "id": "required", "label": "Required", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "RBP onboarding form",
      "blocks": [
        { "type": "field" },
        { "type": "field", "settings": { "type": "email", "label": "Email", "name": "email", "required": true } },
        { "type": "field", "settings": { "type": "textarea", "label": "What do you need help with?", "name": "requirements" } }
      ]
    }
  ]
}
{% endschema %}