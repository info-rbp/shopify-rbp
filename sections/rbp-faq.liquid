<section class="rbp-section">
  <div class="rbp-container">
    {% render 'rbp-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text %}
    <div class="rbp-faq-list">
      {%- for block in section.blocks -%}
        <details {% if forloop.first and section.settings.open_first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question | escape }}</summary>
          <div>{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RBP FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Common questions" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use blocks for editable question and answer content.</p>" },
    { "type": "checkbox", "id": "open_first", "label": "Open first question", "default": true }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What happens after purchase?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>You receive the relevant next-step guidance, and any intake, booking or manual review requirements are confirmed.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "RBP FAQ",
      "blocks": [
        { "type": "question" },
        { "type": "question", "settings": { "question": "Does this replace Shopify checkout?", "answer": "<p>No. RBP sections add context around Shopify's native product, cart and checkout-adjacent flows.</p>" } }
      ]
    }
  ]
}
{% endschema %}
