{%- if collection.products_count == 0 -%}
  <section class="rbp-section">
    <div class="rbp-container">
      <div class="rbp-card">
        <span class="rbp-badge">{{ section.settings.badge | escape }}</span>
        <h2 class="rbp-card__title">{{ section.settings.heading | escape }}</h2>
        <p class="rbp-card__text">{{ section.settings.text | escape }}</p>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "RBP empty collection",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "No products yet" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This collection is being prepared" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Use enquiry or support paths while products are being configured." }
  ],
  "presets": [
    { "name": "RBP collection empty state" }
  ]
}
{% endschema %}
