<section class="rbp-section">
  <div class="rbp-container">
    {% render 'rbp-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text %}
    <div class="rbp-card-grid">
      {%- for block in section.blocks -%}
        <article class="rbp-card" {{ block.shopify_attributes }}>
          <span class="rbp-badge">{{ block.settings.badge | escape }}</span>
          <h3 class="rbp-card__title">{{ block.settings.title | escape }}</h3>
          <p class="rbp-card__text">{{ block.settings.text | escape }}</p>
          {%- if block.settings.url != blank -%}
            <div class="rbp-card__action">
              {% render 'rbp-button', label: block.settings.button_label, url: block.settings.url, variant: 'ghost', size: 'small', arrow: true %}
            </div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RBP service pathways",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Service pathways" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Support by business stage" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use this section to show advisory, consulting, implementation and operations pathways.</p>" }
  ],
  "blocks": [
    {
      "type": "pathway",
      "name": "Pathway",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge", "default": "Advisory" },
        { "type": "text", "id": "title", "label": "Title", "default": "Clarify the decision" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Use structured advice before committing budget, suppliers or internal time." },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "View pathway" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "RBP service pathways",
      "blocks": [
        { "type": "pathway" },
        { "type": "pathway", "settings": { "badge": "Implementation", "title": "Build the operating piece", "text": "Convert decisions into deliverables, workflows and handover assets." } },
        { "type": "pathway", "settings": { "badge": "Operations", "title": "Keep work moving", "text": "Use repeatable support for the tasks that need follow-through." } }
      ]
    }
  ]
}
{% endschema %}
