<section class="rbp-product-section">
  <div class="rbp-product-container">
    {% render 'rbp-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text %}
    <div class="rbp-product-grid rbp-product-grid--2">
      {%- for block in section.blocks -%}
        <article class="rbp-product-card" {{ block.shopify_attributes }}>
          <h3 class="rbp-card__title">{{ block.settings.label | escape }}</h3>
          <p class="rbp-card__text">{{ block.settings.value | escape }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RBP product information",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Product context" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What to know before checkout" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use this section for service inclusions, requirements and delivery context.</p>" }
  ],
  "blocks": [
    {
      "type": "fact",
      "name": "Fact",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Delivery type" },
        { "type": "textarea", "id": "value", "label": "Value", "default": "Prepared digital delivery or guided next step." }
      ]
    }
  ],
  "presets": [
    {
      "name": "RBP product information",
      "blocks": [
        { "type": "fact" },
        { "type": "fact", "settings": { "label": "Requirements", "value": "Customer context may be required before work starts." } }
      ]
    }
  ]
}
{% endschema %}
