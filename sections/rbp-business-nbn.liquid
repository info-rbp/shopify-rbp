<script>
  window.RBP_NBN_CONFIG = {
    temporaryAcceptAll: {{ section.settings.temporary_accept_all | json }},
    checkEndpoint: {{ section.settings.check_endpoint | json }},
    enableGooglePlaces: {{ section.settings.enable_google_places | json }},
    googleBrowserApiKey: {{ section.settings.google_browser_api_key | json }}
  };
</script>
<script src="{{ 'rbp-business-nbn-checker.js' | asset_url }}" defer="defer"></script>

<section class="rbp-section">
  <div class="rbp-container rbp-nbn-shell">
    <div>
      {% render 'rbp-section-heading',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        text: section.settings.text,
        align: 'left'
      %}
      <form id="rbp-nbn-checker" class="rbp-nbn-form">
        <label for="rbp-nbn-address">{{ section.settings.address_label | escape }}</label>
        <input id="rbp-nbn-address" name="address" type="text" autocomplete="street-address" placeholder="{{ section.settings.address_placeholder | escape }}">
        <input id="rbp-nbn-place-id" name="placeId" type="hidden">
        <button id="rbp-nbn-check-btn" class="rbp-button rbp-button--primary" type="submit">Check Availability</button>
      </form>
      <div id="rbp-nbn-result" hidden></div>
      <div id="rbp-nbn-manual-review" class="rbp-card" hidden>
        <h3 class="rbp-card__title">{{ section.settings.manual_heading | escape }}</h3>
        <p class="rbp-card__text">{{ section.settings.manual_text | escape }}</p>
      </div>
    </div>
    <aside class="rbp-card">
      <h3 class="rbp-card__title">{{ section.settings.aside_heading | escape }}</h3>
      <p class="rbp-card__text">{{ section.settings.aside_text | escape }}</p>
      {% render 'rbp-nbn-faq-support' %}
    </aside>
  </div>
</section>

{% schema %}
{
  "name": "RBP Business NBN",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Business NBN" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Check your business address" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Enter the business address to check the next available support pathway. Address qualification, speeds, activation dates, installation requirements and provider approval must be confirmed before any order or activation can proceed.</p>" },
    { "type": "checkbox", "id": "temporary_accept_all", "label": "Use fallback availability mode", "default": true },
    { "type": "text", "id": "check_endpoint", "label": "Availability check endpoint", "default": "/apps/rbp-bridge/api/check-address" },
    { "type": "checkbox", "id": "enable_google_places", "label": "Use address autocomplete", "default": false },
    { "type": "text", "id": "google_browser_api_key", "label": "Address autocomplete browser API key" },
    { "type": "text", "id": "address_label", "label": "Address label", "default": "Business address" },
    { "type": "text", "id": "address_placeholder", "label": "Address placeholder", "default": "Enter street address, suburb and postcode" },
    { "type": "text", "id": "manual_heading", "label": "Manual review heading", "default": "Manual review may be required" },
    { "type": "textarea", "id": "manual_text", "label": "Manual review text", "default": "If the checker cannot confirm serviceability, RBP can review the address, business context and available next steps manually." },
    { "type": "text", "id": "aside_heading", "label": "Aside heading", "default": "Before you choose a plan" },
    { "type": "textarea", "id": "aside_text", "label": "Aside text", "default": "Availability, speed tiers, activation timing, installation requirements and provider approval can vary by address and provider. Confirm these details before relying on a plan." }
  ],
  "presets": [
    { "name": "RBP Business NBN" }
  ]
}
{% endschema %}
