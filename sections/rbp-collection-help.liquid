<section class="rbp-section">
  <div class="rbp-container">
    <div class="rbp-card">
      <span class="rbp-badge">{{ section.settings.badge | escape }}</span>
      <h2 class="rbp-card__title">{{ section.settings.heading | escape }}</h2>
      <p class="rbp-card__text">{{ section.settings.text | escape }}</p>
      {%- if section.settings.button_label != blank -%}
        <div class="rbp-card__action">
          {% render 'rbp-button', label: section.settings.button_label, url: section.settings.button_url, variant: 'secondary', arrow: true %}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RBP collection help",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Need help?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Not sure what to choose?" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Use the support path if the product, service or offer requires context before checkout." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Contact RBP" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [
    { "name": "RBP collection help" }
  ]
}
{% endschema %}
