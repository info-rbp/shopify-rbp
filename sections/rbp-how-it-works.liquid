<section class="rbp-section rbp-surface">
  <div class="rbp-container">
    {% render 'rbp-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text, align: 'left' %}
    <div class="rbp-steps">
      {%- for block in section.blocks -%}
        <article class="rbp-card rbp-step" {{ block.shopify_attributes }}>
          <h3 class="rbp-card__title">{{ block.settings.title | escape }}</h3>
          <p class="rbp-card__text">{{ block.settings.text | escape }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RBP how it works",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How it works" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A clear path from request to next step" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Choose the pathway, share the right context, receive the output or guidance, then move into the next practical step.</p>" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Choose the pathway" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Start with the product, service, resource or support route that matches the business need." }
      ]
    }
  ],
  "presets": [
    {
      "name": "RBP how it works",
      "blocks": [
        { "type": "step" },
        { "type": "step", "settings": { "title": "Share the context", "text": "Provide the issue, desired outcome, timing and any relevant order or service details." } },
        { "type": "step", "settings": { "title": "Receive the next step", "text": "Move forward with the resource, service output, support response or recommended pathway." } }
      ]
    }
  ]
}
{% endschema %}
