{%- comment -%}
  RBP responsive image.

  Accepts:
  - image: desktop/default Shopify image object
  - mobile_image: optional mobile Shopify image object
  - alt: image alt text
  - class: CSS class applied to the img element
  - loading: eager or lazy
  - fetchpriority: high, auto or low
  - sizes: responsive sizes attribute
  - desktop_width: largest desktop render width
  - mobile_width: largest mobile render width
{%- endcomment -%}

{%- liquid
  assign image_object = image
  if image_object == blank and mobile_image != blank
    assign image_object = mobile_image
  endif

  assign image_alt = alt
  if image_alt == blank and image_object != blank
    assign image_alt = image_object.alt
  endif

  assign image_class = class | default: ''
  assign image_loading = loading | default: 'lazy'
  assign image_fetchpriority = fetchpriority | default: 'auto'
  assign image_sizes = sizes | default: '100vw'
  assign desktop_target_width = desktop_width | default: 2400
  assign mobile_target_width = mobile_width | default: 1200
  assign image_widths = widths | default: '360, 480, 640, 800, 960, 1200, 1440, 1800, 2200, 2400'
-%}

{%- if image_object != blank -%}
  <picture>
    {%- if mobile_image != blank -%}
      <source
        media="(max-width: 699px)"
        srcset="
          {{ mobile_image | image_url: width: 360 }} 360w,
          {{ mobile_image | image_url: width: 480 }} 480w,
          {{ mobile_image | image_url: width: 640 }} 640w,
          {{ mobile_image | image_url: width: 800 }} 800w,
          {{ mobile_image | image_url: width: 960 }} 960w,
          {{ mobile_image | image_url: width: mobile_target_width }} {{ mobile_target_width }}w
        "
        sizes="100vw"
        width="{{ mobile_image.width }}"
        height="{{ mobile_image.height }}"
      >
    {%- endif -%}

    {{
      image_object
      | image_url: width: desktop_target_width
      | image_tag:
        alt: image_alt,
        class: image_class,
        loading: image_loading,
        fetchpriority: image_fetchpriority,
        widths: image_widths,
        sizes: image_sizes
    }}
  </picture>
{%- endif -%}
