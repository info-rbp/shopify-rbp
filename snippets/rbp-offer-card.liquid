{% doc %}
@param {metaobject} offer - Partner offer metaobject to render.
@param {boolean} [show_category] - Whether to show the offer category.
@example
{% render 'rbp-offer-card', offer: offer, show_category: true %}
{% enddoc %}

{% liquid
  assign offer_status = offer.status.value | default: offer.status
  assign offer_visibility = offer.visibility.value | default: offer.visibility
  assign offer_cta_url = offer.cta_url.value | default: offer.cta_url
  assign partner = offer.partner.value
  assign partner_status = partner.status.value | default: partner.status
  assign partner_visibility = partner.visibility.value | default: partner.visibility
  assign partner_public = partner.active_public.value | default: partner.is_public.value | default: partner.public.value
  assign partner_is_public = false
  if partner != blank
    if partner_status == 'active'
      if partner_visibility == 'public' or partner_public == true or partner_public == 'true'
        assign partner_is_public = true
      endif
    endif
  endif
%}

{% if offer_status == 'active' %}
  {% if offer_visibility == 'public' %}
    {% if offer_cta_url != blank %}
      {% if partner_is_public %}
        {% liquid
          assign offer_title = offer.title.value | default: offer.name.value | default: 'Partner offer'
          assign offer_description = offer.short_description.value | default: offer.description.value
          assign partner_name = partner.name.value | default: partner.title.value | default: offer.partner_name.value
          assign category = offer.category.value
          assign category_name = category.name.value | default: category.title.value | default: offer.category_name.value
          assign offer_handle = offer.system.handle | default: offer.handle.value | default: offer_title | handleize
          assign offer_url = offer.system.url
          if offer_url == blank
            assign offer_url = '/offers/' | append: offer_handle
          endif
        %}
        <article class="rbp-offer-card">
          <div class="rbp-offer-card__body">
            {% if partner_name != blank %}
              <p class="rbp-offer-card__partner">{{ partner_name }}</p>
            {% endif %}
            <h3>{{ offer_title }}</h3>
            {% if show_category and category_name != blank %}
              <p class="rbp-offer-card__category">{{ category_name }}</p>
            {% endif %}
            {% if offer_description != blank %}
              <p>{{ offer_description }}</p>
            {% endif %}
          </div>
          <div class="rbp-offer-card__actions">
            <a class="rbp-text-link" href="{{ offer_url }}">View Details</a>
            <a class="rbp-text-link rbp-text-link--strong" href="{{ offer_cta_url }}" target="_blank" rel="noopener sponsored">Get Offer</a>
          </div>
        </article>
      {% endif %}
    {% endif %}
  {% endif %}
{% endif %}
